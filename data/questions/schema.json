{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Country question-set entry",
  "type": "object",
  "required": ["iso3", "country", "last_reviewed", "answers"],
  "additionalProperties": false,
  "properties": {
    "iso3": { "type": "string", "pattern": "^[A-Z]{3}$" },
    "country": { "type": "string", "minLength": 1 },
    "last_reviewed": { "type": "string", "format": "date" },
    "answers": {
      "type": "object",
      "required": [
        "digital_id", "cash_payment", "mandatory_schooling", "social_credit",
        "alt_currency", "mandatory_insurance", "travel_restrictions",
        "internet_restrictions", "free_speech"
      ],
      "additionalProperties": false,
      "properties": {
        "digital_id": { "$ref": "#/definitions/answer" },
        "cash_payment": { "$ref": "#/definitions/answer" },
        "mandatory_schooling": { "$ref": "#/definitions/answer" },
        "social_credit": { "$ref": "#/definitions/answer" },
        "alt_currency": { "$ref": "#/definitions/answer" },
        "mandatory_insurance": { "$ref": "#/definitions/answer" },
        "travel_restrictions": { "$ref": "#/definitions/answer" },
        "internet_restrictions": { "$ref": "#/definitions/answer" },
        "free_speech": { "$ref": "#/definitions/answer" }
      }
    }
  },
  "definitions": {
    "answer": {
      "type": "object",
      "required": ["value", "note", "sources"],
      "additionalProperties": false,
      "properties": {
        "value": { "type": "string", "enum": ["yes", "partial", "no", "unclear"] },
        "note": { "type": "string", "minLength": 20 },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["url", "title", "accessed"],
            "additionalProperties": false,
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "title": { "type": "string", "minLength": 1 },
              "accessed": { "type": "string", "format": "date" }
            }
          }
        }
      }
    }
  }
}
